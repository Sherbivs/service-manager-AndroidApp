{
  "name": "service-manager",
  "version": "1.0.0",
  "description": "Elastic service management dashboard — manage, monitor, and control local dev services from a single web UI",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "service:install": "node service-install.js",
    "service:uninstall": "node service-uninstall.js",
    "tray": "wscript.exe launch-tray.vbs"
  },
  "dependencies": {
    "express": "^4.21.0",
    "node-windows": "^1.0.0-beta.8"
  }
}
